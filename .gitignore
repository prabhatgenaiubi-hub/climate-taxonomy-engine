# ─── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
*.whl
pip-wheel-metadata/

# ─── Virtual environments ────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
.env
.env.*

# ─── Jupyter / IPython ───────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ─── Streamlit ───────────────────────────────────────────────────────────────
.streamlit/
ui/ap.log

# ─── ML / Model artefacts ────────────────────────────────────────────────────
# Keep model files tracked via Git LFS (*.safetensors in .gitattributes)
# Ignore common large binary formats NOT already in LFS:
*.bin
*.pt
*.pth
*.ckpt
*.h5
*.hdf5
*.pkl
*.pickle
# Do NOT ignore *.safetensors — those are tracked via Git LFS

# ─── Data ────────────────────────────────────────────────────────────────────
# Uncomment lines below if you want to exclude raw/processed data from git
# data/raw/
# data/processed/
# data/filtered/
# data/classified/
# data/vulnerabilities/
# data/labeled/
# data/ocr_pdfs/

# ─── Vector DB ───────────────────────────────────────────────────────────────
# vector_db/ contains FAISS index binaries — uncomment to exclude if large
# vector_db/

# ─── OS / IDE ────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
.idea/
.vscode/
*.code-workspace

# ─── Coverage / testing ──────────────────────────────────────────────────────
.coverage
htmlcov/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ─── Logs ────────────────────────────────────────────────────────────────────
*.log
logs/
